docker.enabled = true

// Process-level settings
process {
    withLabel: 'process_gpu' {
        containerOptions = '--gpus all'
    }
}

// Pipeline parameters
params {
    eval_dir = 'data/processed/evaluation_dataset'
    tools_dir = 'data/raw/tools'
    models_dir = 'models'
    lmpred_skip_training = true
    amp_bert_skip_training = true
    kt_amppred_skip_training = true
    plapd_skip_training = true
}

// Output settings
outputDir            = 'results'
workflow.output.mode = 'copy'
